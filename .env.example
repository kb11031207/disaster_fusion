# Copy this file to .env and fill in real values. .env is gitignored.
#
# READ FIRST:
# AWS_ACCESS_KEY_ID is NOT the same as AWS_ACCOUNT_ID.
#   - AWS_ACCESS_KEY_ID starts with "AKIA..." (or "ASIA..." for temp creds)
#   - AWS_ACCOUNT_ID   is the 12-digit number identifying the AWS account;
#                      it goes in the S3 bucketOwner field, not in credentials.
# First thing at the hackathon: ask organizers
#   (1) which S3 bucket can we write to?
#   (2) how do we authenticate to Bedrock? (keys vs IAM role vs SSO)

# ---------------------------------------------------------------------------
# AWS region (always required)
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# OPTION A: Explicit credentials (laptop, local dev, or keys from organizers)
# Fill these in only if you were given access keys.
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=          # starts with AKIA... or ASIA...
AWS_SECRET_ACCESS_KEY=      # long secret string
AWS_SESSION_TOKEN=          # only if using temporary credentials

# ---------------------------------------------------------------------------
# OPTION B: Workshop / managed environment (SageMaker, Cloud9, EC2)
# Leave the three keys above BLANK — boto3 will pick up the attached IAM role
# automatically. You still need AWS_REGION set above.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Account ID — used for the bucketOwner field in cross-account S3 calls.
# Different from the access key. 12-digit number.
# ---------------------------------------------------------------------------
AWS_ACCOUNT_ID=

# ---------------------------------------------------------------------------
# S3 bucket for video uploads and Marengo async embedding output.
# Get this from the hackathon organizers. Do NOT assume you can write to the
# workshop instructor's bucket.
# ---------------------------------------------------------------------------
S3_BUCKET=
S3_VIDEOS_PATH=videos
S3_EMBEDDINGS_PATH=embeddings

# ---------------------------------------------------------------------------
# Model IDs
# Pegasus + Marengo confirmed from TwelveLabs workshop notebook.
# Claude is called via AWS Bedrock (no separate Anthropic SDK / API key).
# Code auto-falls back to the regional inference profile prefix (us.) if the
# bare ID is rejected with a "inference profile" ValidationException.
# ---------------------------------------------------------------------------
PEGASUS_MODEL_ID=us.twelvelabs.pegasus-1-2-v1:0
MARENGO_MODEL_ID=twelvelabs.marengo-embed-3-0-v1:0
MARENGO_INFERENCE_ID=us.twelvelabs.marengo-embed-3-0-v1:0
CLAUDE_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0
