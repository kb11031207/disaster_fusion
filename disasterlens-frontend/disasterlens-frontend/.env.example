# GeoArbiter frontend environment
#
# Copy this file to `.env.local` and adjust as needed. Vite only exposes
# variables prefixed with `VITE_` to the browser.

# Base URL the frontend uses for backend calls.
#   - In dev, leave as "/api" so requests go through the vite proxy.
#   - In prod (S3/CloudFront/Amplify), set this to the public backend host.
VITE_API_BASE=/api

# Where the dev-server proxy forwards `/api/*` to. Only used by vite.config.js.
# Override when running the backend somewhere other than localhost.
# Current shared dev backend (EC2):
#   VITE_API_PROXY_TARGET=http://10.200.5.39:8000
VITE_API_PROXY_TARGET=http://localhost:8000

# Optional: load the bundled static Katrina dataset instead of calling the
# backend. Useful for offline demos when the EC2 box is unreachable.
# Set to "1" to enable.
VITE_DEMO_MODE=0
